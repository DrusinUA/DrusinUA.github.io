<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100%" height="100%">
  <!-- Green background from the "кафе" badge -->
  <rect width="100" height="100" fill="#3c4f36" rx="20"/>
  
  <!-- Stylized Letter C -->
  <!-- Similar to the first C in COCOS wordmark -->
  <path d="M 75 80 C 40 100, 10 90, 15 50 C 20 10, 60 10, 85 25" fill="none" stroke="#fdfbf7" stroke-width="18" stroke-linecap="round"/>
</svg>
